// Backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// VENDOR & STORE

model Vendor {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  fullName            String
  
  // Contact & Socials
  phone               String?
  whatsapp            String?
  instagram           String?
  facebook            String?
  twitter             String?
  
  // Store Details
  storeName           String?
  storeLink           String?   @unique
  storeCategory       String?   // Mapped from Settings.jsx
  storeDescription    String?
  logoUrl             String?
  isOnline            Boolean   @default(true) // Defaulted to true so stores are live immediately
  
  // Store Appearance
  themeColor          String    @default("#044e3b")
  hasBanner           Boolean   @default(false)
  bannerImage         String?
  bannerTitle         String?
  bannerSubtitle      String?
  bannerDiscount      String?

  // Business Details
  businessName        String?
  cacNumber           String?
  businessAddress     String?
  showBusinessDetails Boolean   @default(false)

  // Payment Details
  bankName            String?
  accountNumber       String?
  accountName         String?

  // Delivery Settings
  deliveryFee         Decimal?  @db.Decimal(10, 2)
  deliveryTime        String?   @default("2-3 Business Days")

  // Pricing Plan (Free, Starter, Growth)
  plan                String    @default("FREE")
  
  // Relationships
  products            Product[]
  orders              Order[]
  customers           Customer[]
  categories          Category[] // <-- NEW: Link to categories
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// CATEGORIES

model Category {
  id        String   @id @default(uuid())
  vendorId  String
  name      String
  
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ensures a vendor can't create two categories with the exact same name
  @@unique([vendorId, name])
}

// PRODUCTS

model Product {
  id               String    @id @default(uuid())
  vendorId         String    
  name             String
  description      String?
  price            Decimal   @db.Decimal(10, 2)
  compareAtPrice   Decimal?  @db.Decimal(10, 2) 
  stockQuantity    Int       @default(0)
  category         String
  status           String    @default("ACTIVE") 
  imageUrls        String[]  
  
  vendor           Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// CUSTOMERS 

model Customer {
  id               String    @id @default(uuid())
  vendorId         String    
  fullName         String
  email            String?
  phone            String
  address          String?
  
  vendor           Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders           Order[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ORDERS & ORDER ITEMS

model Order {
  id               String    @id @default(uuid()) 
  orderNumber      String    @unique              
  vendorId         String
  customerId       String
  
  totalAmount      Decimal   @db.Decimal(10, 2)
  deliveryFee      Decimal   @default(0.00) @db.Decimal(10, 2)
  
  status           String    @default("PENDING")  
  paymentMethod    String?   
  paymentStatus    String    @default("UNPAID")   
  customerNote     String?
  
  vendor           Vendor    @relation(fields: [vendorId], references: [id])
  customer         Customer  @relation(fields: [customerId], references: [id])
  items            OrderItem[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model OrderItem {
  id               String    @id @default(uuid())
  orderId          String
  productId        String
  
  quantity         Int
  priceAtPurchase  Decimal   @db.Decimal(10, 2) 
  
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product   @relation(fields: [productId], references: [id])
}